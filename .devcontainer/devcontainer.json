// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/php
{
  "name": "PHP",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/php:3-8.3-trixie",

  // Features to add to the dev container. More info: https://containers.dev/features.
  // "features": {},

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "wongjn.php-sniffer",
        "esbenp.prettier-vscode"
      ]
    }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [8080],

  // Patch Xdebug to use trigger mode so CLI tools (composer, phpcs, phpunit) don't
  // emit "Could not connect to debugging client" warnings. VS Code debugging still works
  // because the PHP Debug extension sets XDEBUG_TRIGGER automatically.
  "postCreateCommand": "sudo sed -i 's/xdebug.mode = debug/xdebug.mode = off/' /usr/local/etc/php/conf.d/xdebug.ini && sudo sed -i 's/xdebug.start_with_request = yes/xdebug.start_with_request = trigger/' /usr/local/etc/php/conf.d/xdebug.ini"

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
